# Obsidian vault
OBSIDIAN_VAULT_PATH=/path/to/your/vault

# Vector store backend: "pgvector" (vectors in PostgreSQL) or "qdrant" (dedicated vector DB)
VECTOR_BACKEND=pgvector
COLLECTION_NAME=obsidian

# Qdrant (only needed when VECTOR_BACKEND=qdrant)
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=change-me-to-a-strong-secret

# Embeddings
EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=sk-...

# PostgreSQL (DSN is built from these — or set POSTGRES_DSN directly to override)
POSTGRES_USER=mnemolith
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=mnemolith
POSTGRES_PORT=5435

# Phase 1c — Neo4j backs the Graphiti temporal knowledge graph.
# Default URI matches the docker-compose neo4j service.
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme-graphiti

# Graphiti uses Anthropic by default to match the rest of the LevelUp stack.
# Override to "openai" if cost or latency drives that choice.
GRAPHITI_LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
# Optional: explicit model overrides
# GRAPHITI_LLM_MODEL=claude-sonnet-4-6
# GRAPHITI_EMBEDDING_MODEL=text-embedding-3-small
